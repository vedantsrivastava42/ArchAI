# ============== Database (required) ==============
# Postgres: from Neon (neon.tech) or Supabase (supabase.com) → use "Direct connection" / connection string.
# Supabase: replace [YOUR-PASSWORD] with your DB password; add ?sslmode=require if needed.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# ============== Job queue (required for indexing) ==============
# Redis: used by BullMQ for indexing jobs. Use Upstash (upstash.com) or any Redis URL; no local Redis needed.
# REDIS_URL=rediss://default:YOUR_TOKEN@xxx.upstash.io:6379
REDIS_URL=

# ============== Vector DB (required) ==============
# Qdrant Cloud: cluster URL from cloud.qdrant.io. Or local: http://localhost:6333 if you run Qdrant binary.
QDRANT_URL=https://xxxxx.cloud.qdrant.io
# Only if your Qdrant host requires an API key:
# QDRANT_API_KEY=

# ============== AI (required) — OpenAI used for embeddings + chat ==============
OPENAI_API_KEY=

# ============== Optional ==============
# If you still get "self-signed certificate" with Supabase, uncomment (dev only):
# NODE_TLS_REJECT_UNAUTHORIZED=0
# Private GitHub repos (add token for clone access)
# GITHUB_TOKEN=ghp_...

# Server port and host (default 3001, 0.0.0.0 so the server is reachable from the internet on EC2)
# PORT=3001
# HOST=0.0.0.0

# ============== Deployment (FE on Vercel, BE on EC2) ==============
# Backend (EC2): allow frontend origin(s). Comma-separated for multiple.
# CORS_ORIGIN=https://your-app.vercel.app

# Frontend (Vercel): set in Vercel project → Settings → Environment Variables
# NEXT_PUBLIC_API_URL=https://your-ec2-api-url.com
